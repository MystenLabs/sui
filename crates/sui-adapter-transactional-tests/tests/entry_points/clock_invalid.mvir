//# init --accounts A B --addresses test=0x0

//# publish --sender A
mvir 0x0::m {
    import 0x2::clock;

    entry fun entry_clock_mut(c: &mut clock::Clock) {
        label l0:
        abort 0;
    }

    entry fun entry_clock_owned(c: clock::Clock) {
        label l0:
        abort 0;
    }

    public fun public_clock_mut(c: &mut clock::Clock) {
        label l0:
        abort 0;
    }

    public fun public_clock_owned(c: clock::Clock) {
        label l0:
        abort 0;
    }

}

