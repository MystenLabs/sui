mvir 0x0::f {
    import 0x2::transfer;

    public enum X has key {
        A { } 
    }

    public fun transfer() {
        let x: Self::X;
        label l0:
            x = X::A { };
            transfer::transfer<Self::X>(move(x), 0x0);
        return;
    }

    public fun share() {
        let x: Self::X;
        label l0:
            x = X::A { };
            transfer::share_object<Self::X>(move(x));
        return;
    }

    public fun freezer() {
        let x: Self::X;
        label l0:
            x = X::A { };
            transfer::freeze_object<Self::X>(move(x));
        return;
    }
}

