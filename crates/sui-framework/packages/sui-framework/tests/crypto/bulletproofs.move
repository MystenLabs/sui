#[allow(implicit_const_copy), test_only]
module sui::ristretto255_tests;

use std::unit_test::assert_eq;
use sui::group_ops;
use sui::ristretto255;

#[test]
fun test_bulletproof() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
    assert!(verify_range_proof_ristretto255(&proof, 32, &vector[commitment], 0));
}

#[test]
fun test_batch_bulletproof() {
    let proof =
        x"";
    let commitments = [
        ristretto255::g_from_bytes(x"709b9120cad09076c05b30dcaacb4541b284c04baaa74e4f6af9d29688ead950"),
        ristretto255::g_from_bytes(x"20053eda9db252068b610c0c87afa6c408c6732991f70fec08f12a74000ee97b"),
        ristretto255::g_from_bytes(x"649646803a3a12353a07adca0085d304e6d5558a84713914971595bce97f177e"),
        ristretto255::g_from_bytes(x"18d7ee6961ba0c98a2dbd9bba68c8acadb78c4dede3e5c506b6e12198fcdca11"),
    ];
    assert!(verify_range_proof_ristretto255(&proof, 16, &commitments, 0));
}

#[test]
fun test_invalid_bulletproof() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
    assert!(!verify_range_proof_ristretto255(&proof, 32, &vector[commitment], 0));
}

#[test]
#[expected_failure(abort_code = sui::bulletproofs::EInvalidProof)]
fun test_bulletproof_wrong_length() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
    verify_range_proof_ristretto255(&proof, 32, &vector[commitment], 0);
}

#[test]
#[expected_failure(abort_code = sui::bulletproofs::EInvalidRange)]
fun test_bulletproof_invalid_range() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
    verify_range_proof_ristretto255(&proof, 42, &vector[commitment], 0);
}


#[test]
#[expected_failure(abort_code = sui::bulletproofs::EInvalidBatchSize)]
fun test_bulletproof_invalid_batch_size() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
    verify_range_proof_ristretto255(&proof, 42, &vector[commitment, commitment, commitment], 0);
}

