#[test]
#[expected_failure(abort_code = sui::bulletproofs::EInvalidProof)]
fun test_bulletproof_wrong_length() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
    verify_range_proof_ristretto255(&proof, 32, &vector[commitment], 0);
}

#[test]
#[expected_failure(abort_code = sui::bulletproofs::EInvalidRange)]
fun test_bulletproof_invalid_range() {
    let proof =
        x"";
    let commitment = ristretto255::g_from_bytes(x"c026d2b1790b3391f991ad4a2ad62e3ae5db6da3eeb2280aa83bd6018fe3967b");
