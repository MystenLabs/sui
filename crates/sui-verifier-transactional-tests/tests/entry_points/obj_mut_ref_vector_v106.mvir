// invalid, a mutable reference to vector of objects

//# init --protocol-version 106

//# publish
mvir 0x0::m {
    import 0x2::object;
    import 0x2::tx_context;

    public struct S has key { id: object::UID }

    public entry fun no(s: &mut vector<Self::S>, ctx: &mut tx_context::TxContext) {
        label l0:
        abort 0;
    }

}
