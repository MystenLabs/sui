//# publish
// allowed since no object is being created with the UID
mvir 0x0::m {
    import 0x2::object;

    struct Foo has key {
        id: object::UID,
    }

    fun transfer(id: object::UID) {
        label l0:
        abort 0;
    }

    fun foo(f: Self::Foo, v: &mut vector<object::UID>) {
        let id: object::UID;
        label l0:
        Foo { id } = move(f);
        Self::transfer(move(id));
        return;
    }

}
