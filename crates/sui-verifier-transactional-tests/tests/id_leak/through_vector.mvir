//# publish
// allowed, anything can be done with a UID after unpacking, as long as it isn't repacked
mvir 0x0::m {
    import 0x2::object;

    public struct Foo has key {
        id: object::UID,
    }

    fun foo(f: Self::Foo, v: &mut vector<object::UID>) {
        let id: object::UID;
        label l0:
        Foo { id } = move(f);
        vec_push_back<object::UID>(move(v), move(id));
        return;
    }

}
