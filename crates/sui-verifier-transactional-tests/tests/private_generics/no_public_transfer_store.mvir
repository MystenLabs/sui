// tests modules cannot use transfer internal functions outside of the defining module

//# publish
mvir 0x0::m {
    import 0x2::coin;
    import 0x2::transfer;

    fun t(s: coin::Coin<u64>) {
        label l0:
        transfer::transfer<coin::Coin<u64>>(move(s), 0x100);
        return;
    }
}

//# publish
mvir 0x0::m {
    import 0x2::coin;
    import 0x2::transfer;

    fun t(s: coin::Coin<u64>) {
        label l0:
        transfer::freeze_object<coin::Coin<u64>>(move(s));
        return;
    }
}

