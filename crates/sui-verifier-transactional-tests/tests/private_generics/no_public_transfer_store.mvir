//# publish
mvir 0x0::m {
    import 0x2::coin;
    import 0x2::transfer;
    import 0x2::object;

    fun t(uid: &mut object::UID, coin: transfer::Receiving<coin::Coin<u64>>): coin::Coin<u64> {
        let c: coin::Coin<u64>;
        label l0:
        c = transfer::receive<coin::Coin<u64>>(move(uid), move(coin));
        return move(c);
    }
}

//# publish
mvir 0x0::m {
    import 0x2::coin;
    import 0x2::transfer;
    import 0x2::party;

    fun t(s: coin::Coin<u64>, p: party::Party) {
        label l0:
        transfer::party_transfer<coin::Coin<u64>>(move(s), move(p));
        return;
    }
}
