// tests modules cannot use transfer internal functions outside of the defining module
// Note: it is not possible to make a generic type `T<...> has key, store`
// where a given instantiation`T<...>` has key but does _not_ have store

//# init --addresses test=0x0

//# publish
mvir 0x0::m {
    import 0x2::transfer;

    fun t<T: key + store>(s: T) {
        label l0:
        transfer::transfer<T>(move(s), 0x100);
        return;
    }
}

//# publish
mvir 0x0::m {
    import 0x2::transfer;

    fun t<T: key + store>(s: T) {
        label l0:
        transfer::freeze_object<T>(move(s));
        return;
    }
}

//# publish
mvir 0x0::m {
    import 0x2::transfer;

    fun t<T: key + store>(s: T) {
        label l0:
        transfer::share_object<T>(move(s));
        return;
    }
}

//# publish
mvir 0x0::m {
    import 0x2::transfer;
    import 0x2::object;

    fun t<T: key + store>(uid: &mut object::UID, coin: transfer::Receiving<T>): T {
        let c: T;
        label l0:
        c = transfer::receive<T>(move(uid), move(coin));
        return move(c);
    }
}

//# publish
mvir 0x0::m {
    import 0x2::transfer;
    import 0x2::party;

    fun t<T: key + store>(s: T, p: party::Party) {
        label l0:
        transfer::party_transfer<T>(move(s), move(p));
        return;
    }
}
