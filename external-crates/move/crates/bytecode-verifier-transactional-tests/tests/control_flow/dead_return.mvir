//# publish

// TODO: we might need to modify this test if we enable unreachable code
// checking in the verifier.

mvir 0x1::Test {
    public fun t(): u64 {
    label b0:
        return 100;
        return 0;
    }
}

//# run
mvir 0x42::m {

import 0x1::Test;
entry fun foo() {
    let x: u64;
label b0:
    x = Test::t();
    assert(copy(x) == 100, 42);
    return;
}
}
