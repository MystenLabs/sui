//# init --edition development

//# publish
module 0x1.M1 {
    public if_else_signed(cond: bool) {
        let x: i64;
    label b0:
        x = 1i64;
        jump_if (move(cond)) done;
    label alt:
        x = 2i64;
    label done:
        return;
    }
}

//# publish
module 0x2.M2 {
    public loop_signed() {
        let counter: u64;
        let sum: i32;
    label b0:
        counter = 0;
        sum = 0i32;
    label loop_head:
        jump_if (copy(counter) < 10) loop_body;
        jump loop_end;
    label loop_body:
        sum = copy(sum) + 1i32;
        counter = copy(counter) + 1;
        jump loop_head;
    label loop_end:
        return;
    }
}
