//# init --edition development

// Test generic functions/structs instantiated with signed integer types
// No instantiation loops here, so these should all pass verification.

//# publish
module 0x1.M1 {
    struct S<T> { val: T }

    // Generic function instantiated with i8
    public make_i8(): Self.S<i8> {
    label b0:
        return S<i8> { val: 0i8 };
    }

    // Generic function instantiated with i64
    public make_i64(): Self.S<i64> {
    label b0:
        return S<i64> { val: 0i64 };
    }
}

//# publish
module 0x2.M2 {
    struct Box<T> { val: T }

    // Generic function that takes T, called with signed ints
    public wrap<T>(x: T): Self.Box<T> {
    label b0:
        return Box<T> { val: move(x) };
    }

    public wrap_i8(x: i8): Self.Box<i8> {
    label b0:
        return Self.wrap<i8>(move(x));
    }

    public wrap_i16(x: i16): Self.Box<i16> {
    label b0:
        return Self.wrap<i16>(move(x));
    }

    public wrap_i128(x: i128): Self.Box<i128> {
    label b0:
        return Self.wrap<i128>(move(x));
    }
}
