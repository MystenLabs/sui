//# publish
mvir 0x1::M {
    public struct R { f:bool }
    fun t0() {
        let r: Self::R;
        let f: bool;
    label b0:
        r = R{ f: false };
        jump_if (true) b2;
    label b1:
        R{ f: f } = move(r);
        r = R{ f: false };
        jump b3;
    label b2:
        R{ f: f } = move(r);
    label b3:
        R{ f: f } = move(r); // invalid move loc
        return;
    }
}

