//# init --edition development

// i8: assign and copy
//# publish
module 0x6.I8AssignCopy {
    test() {
        let x: i8;
        let y: i8;
    label l0:
        x = 42i8;
        y = copy(x);
        assert(copy(y) == 42i8, 42);
        return;
    }
}

// i8: assign and move
//# publish
module 0x7.I8AssignMove {
    test() {
        let x: i8;
        let y: i8;
    label l0:
        x = 42i8;
        y = move(x);
        assert(copy(y) == 42i8, 42);
        return;
    }
}

