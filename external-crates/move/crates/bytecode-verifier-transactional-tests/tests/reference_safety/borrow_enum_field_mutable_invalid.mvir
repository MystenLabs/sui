//# publish
mvir 0x1::M {
    public enum E has drop {
        V { f0: u64 }
    }

    fun foo(b: bool, in: &mut Self::E, other: Self::E) {
        let x: &mut u64;
        let y: &Self::E;
        let ye: &u64;
    label start:
        jump_if (move(b)) t;
    label f:
        // Borrow mut ref
        &mut E::V { f0: x } = copy(in);
        // fill y with a different immut ref
        y = &other;
        jump end;
    label t:
        // Freeze the ref
        y = freeze(move(in));
    label end:
        &E::V { f0: ye } = move(y);
        return;
    }
}

