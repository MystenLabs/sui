//# publish
mvir 0x1::Tester {
    fun eqtest1() {
        let x: u64;
        let r: &mut u64;
    label b0:
        x = 0;
        r = &mut x;
        // invalid read of mutable ref, does not currently own its data
        _ = copy(r) == copy(r);
        return;
    }
}

