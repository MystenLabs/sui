//# publish

// testing valid usages of == and != over references
mvir 0x1::Tester {
    fun eqtest1() {
        let x: u64;
        let r: &mut u64;
    label b0:
        x = 0;
        r = &mut x;
        _ = freeze(copy(r)) == freeze(copy(r));
        return;
    }

    fun eqtest2() {
        let x: u64;
        let r: &mut u64;
    label b0:
        x = 0;
        r = &mut x;
        _ = freeze(copy(r)) == freeze(move(r));
        return;
    }

    fun neqtest1() {
        let x: u64;
        let r: &mut u64;
    label b0:
        x = 0;
        r = &mut x;
        _ = freeze(copy(r)) != freeze(copy(r));
        return;
    }

    fun neqtest2() {
        let x: u64;
        let r: &mut u64;
    label b0:
        x = 0;
        r = &mut x;
        _ = freeze(copy(r)) != freeze(move(r));
        return;
    }
}
