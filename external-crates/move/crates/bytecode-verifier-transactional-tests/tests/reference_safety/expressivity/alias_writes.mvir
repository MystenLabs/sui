// writing to alias writes should be consistent

//# publish

mvir 0x2::borrow_local_twice {

fun t() {
    let a: u64;
    let x: &mut u64;
    let y: &mut u64;
label b0:
    a = 0;
    x = &mut a;
    y = &mut a;
    *move(x) = 0;
    *move(y) = 0;
    return;
}

}

//# publish

mvir 0x3::borrow_local_twice_reverse {

fun t() {
    let a: u64;
    let x: &mut u64;
    let y: &mut u64;
label b0:
    a = 0;
    x = &mut a;
    y = &mut a;
    *move(y) = 0;
    *move(x) = 0;
    return;
}

}

//# publish

mvir 0x4::borrow_local_and_copy_ref {

fun t() {
    let a: u64;
    let x: &mut u64;
    let y: &mut u64;
label b0:
    a = 0;
    x = &mut a;
    y = copy(x);
    *move(x) = 0;
    *move(y) = 0;
    return;
}

}

//# publish

mvir 0x5::borrow_local_and_copy_ref_reverse {

fun t() {
    let a: u64;
    let x: &mut u64;
    let y: &mut u64;
label b0:
    a = 0;
    x = &mut a;
    y = copy(x);
    *move(y) = 0;
    *move(x) = 0;
    return;
}

}
