// can borrow immutable after mutable

//# publish
mvir 0x2::direct {

    fun t() {
        let a: u64;
        let rmut: &mut u64;
        let rimm: &u64;
    label b0:
        a = 0;
        rmut = &mut a;
        rimm = &a;
        // rmut is writable and rimm is readable
        *copy(rmut) = 0;
        _ = *copy(rimm);
        return;
    }
}

//# publish
mvir 0x3::copy_and_freeze {

    fun t() {
        let a: u64;
        let rmut: &mut u64;
        let rimm: &u64;
    label b0:
        a = 0;
        rmut = &mut a;
        rimm = freeze(copy(rmut));
        // rmut is writable and rimm is readable
        *copy(rmut) = 0;
        _ = *copy(rimm);
        return;
    }
}
