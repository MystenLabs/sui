// all mutable return values of a call should writable

//# publish

mvir 0x2::Tester {

public struct Point has copy, drop, store { x: u64, y: u64 }

fun borrow(p: &mut Self::Point): &mut u64 * &mut u64 {
label b0:
    return &mut copy(p).Point::x, &mut copy(p).Point::y;
}

fun write(p: &mut Self::Point) {
    let x: &mut u64;
    let y: &mut u64;
label b0:
    x, y = Self::borrow(copy(p));
    *copy(x) = 0;
    *copy(y) = 0;
    *copy(x) = 0;
    *copy(y) = 0;
    return;
}

}
