//# run --type-args u64 --args 0
mvir 0x1::m {
// all invalid signatures
entry fun foo<T: copy + drop>(x: T) {
label b0:
    return;
}
}


//# run --type-args u8 --args 1u8
mvir 0x2::m {

entry fun foo<T>(x: &T) {
label b0:
    return;
}

}

//# run --type-args u8 --args b"hello"
mvir 0x3::m {

entry fun foo<T: copy + drop>(v: vector<T>) {
label b0:
    return;
}

}

//# publish
mvir 0x42::M {
    public struct Box<T> has drop { x: T }
}


//# run --type-args u8 --args 0u8
mvir 0x4::m {
// bit of a hack but works because structs have no overhead
import 0x42::M;

entry fun foo<T: copy + drop>(x: M::Box<M::Box<T>>) {
label b0:
    return;
}
}
