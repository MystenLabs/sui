//# run --signers 0x1
mvir 0x42::m {
// missing signer
entry fun foo(s: signer, s2: signer) {
label b0:
    return;
}
}

//# run --signers 0x1 --args 0
mvir 0x1::m {
// missing signer
entry fun foo(s: signer, s2: signer,  u: u64,) {
label b0:
    return;
}
}

//# run --args @0x1 0 @0x2
mvir 0x2::m {
// no longer an invalid signature, after V5
entry fun foo(s: signer, u: u64, s2: signer) {
label b0:
    return;
}
}
