//# init --edition development

// Test function signatures with signed integer types

//# publish
module 0x1.M1 {
    // Function taking an i8 parameter
    public take_i8(x: i8): i8 {
    label b0:
        return move(x);
    }
}

//# publish
module 0x2.M2 {
    // Function returning an i64
    public ret_i64(): i64 {
    label b0:
        return 42i64;
    }
}

//# publish
module 0x3.M3 {
    // Function with multiple signed int params of different widths
    public multi_signed(a: i8, b: i16, c: i32, d: i64, e: i128, f: i256): i8 {
    label b0:
        return move(a);
    }
}

//# publish
module 0x4.M4 {
    // Struct with signed integer fields
    struct SignedFields has drop {
        f8: i8,
        f16: i16,
        f32: i32,
        f64: i64,
        f128: i128,
        f256: i256
    }

    public make(): Self.SignedFields {
    label b0:
        return SignedFields {
            f8: 1i8,
            f16: 2i16,
            f32: 3i32,
            f64: 4i64,
            f128: 5i128,
            f256: 6i256
        };
    }
}
