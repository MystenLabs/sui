//# publish
mvir 0x6::Test {
    public fun foo(v: u64): u64 * u64 {
        let one_less: u64;
        let one_more: u64;
    label b0:
        one_less = copy(v) - 1;
        one_more = move(v) + 1;
        return move(one_less), move(one_more);
    }

    public fun bar(): u64 * u64 * u64 {
    label b0:
        return 500, 8, 256;
    }
}

//# run
mvir 0x42::m {
import 0x6::Test;

entry fun foo() {
    let y: u64;
    let x0: u64;
    let x1 : u64;
label b0:
    // positive stack
    x0, x1 = Test::foo(Test::bar());
    assert(move(x0) == 8, 42);
    assert(move(x1) == 256, 42);
    return;
}
}
