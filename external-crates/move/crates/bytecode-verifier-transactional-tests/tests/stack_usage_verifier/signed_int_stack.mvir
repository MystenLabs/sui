// Test balanced stack with signed integer two-return function (i8)
//# publish
module 0xc.BalancedI8 {
    two(): i8 * i8 {
    label b0:
        return 0i8, 127i8;
    }

    pop() {
    label b0:
        _, _ = Self.two();
        return;
    }
}

// Test balanced stack with signed integer two-return function (i16)
//# publish
module 0xd.BalancedI16 {
    two(): i16 * i16 {
    label b0:
        return 0i16, 32767i16;
    }

    pop() {
    label b0:
        _, _ = Self.two();
        return;
    }
}

