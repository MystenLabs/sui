// Test arithmetic operations balance the stack (consume 2, push 1)
//# publish
module 0x12.ArithI8 {
    test() {
        let x: i8;
    label l0:
        x = 1i8 + 2i8;
        x = 10i8 - 3i8;
        x = 4i8 * 5i8;
        x = 20i8 / 4i8;
        x = 17i8 % 5i8;
        return;
    }
}

// Test arithmetic operations balance the stack (i64)
//# publish
module 0x13.ArithI64 {
    test() {
        let x: i64;
    label l0:
        x = 100i64 + 200i64;
        x = 500i64 - 123i64;
        x = 10i64 * 20i64;
        x = 100i64 / 7i64;
        x = 100i64 % 7i64;
        return;
    }
}

// Test comparison operations balance the stack (consume 2, push 1 bool)
//# publish
module 0x14.CmpI8 {
    test() {
        let b: bool;
    label l0:
        b = 1i8 < 2i8;
        b = 2i8 > 1i8;
        b = 1i8 <= 1i8;
        b = 2i8 >= 1i8;
        b = 1i8 == 1i8;
        b = 1i8 != 2i8;
        return;
    }
}

// Test bitwise operations balance the stack (consume 2, push 1)
//# publish
module 0x15.BitwiseI64 {
    test() {
        let x: i64;
        let s: u8;
    label l0:
        x = 255i64 & 15i64;
        x = 240i64 | 15i64;
        x = 255i64 ^ 128i64;
        s = 4u8;
        x = 1i64 << copy(s);
        x = 16i64 >> move(s);
        return;
    }
}
