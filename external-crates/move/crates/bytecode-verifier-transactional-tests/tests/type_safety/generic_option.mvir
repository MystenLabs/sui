//# publish

// example using generics in a few common/interesting/non-trivial ways
mvir 0x42::Option {
    import 0x1::vector;

    public struct T<E> has copy, drop, store {
        v: vector<E>
    }

    public fun none<E: store>(): Self::T<E> {
    label b0:
        return T<E> { v: vector::empty<E>() };
    }

    public fun some<E: store>(e: E): Self::T<E> {
        let v: vector<E>;
    label b0:
        v = vector::empty<E>();
        vector::push_back<E>(&mut v, move(e));
        return T<E> { v: move(v) };
    }

    public fun unwrap_or<E: copy + drop + store>(x: Self::T<E>, e: E): E {
        let v: vector<E>;
    label b0:
        T<E> { v: v } = move(x);
        jump_if (vector::is_empty<E>(&v)) b2;
    label b1:
        return vector::pop_back<E>(&mut v);
    label b2:
        return move(e);
    }

    public fun really_none<E: copy + drop + store>(): Self::T<E> {
    label b0:
        return Self::unwrap_or<Self::T<E>>(Self::none<Self::T<E>>(), Self::none<E>());
    }
}

//# publish

// example using generics in a few common/interesting/non-trivial ways -- with actual enums!
mvir 0x43::Option {
    public enum T<E> has copy, drop, store {
        None { },
        Some { v: E }
    }

    public fun none<E: store>(): Self::T<E> {
    label b0:
        return T::None<E> { };
    }

    public fun some<E: store>(e: E): Self::T<E> {
    label b0:
        return T::Some<E> { v: move(e) };
    }

    public fun unwrap_or<E: copy + drop + store>(x: Self::T<E>, e: E): E {
        let v: E;
    label b0:
        variant_switch T (&x) {
            None : b1,
            Some : b2,
        };
    label b1:
        T::Some<E> { v: v } = move(x);
        return move(v);
    label b2:
        return move(e);
    }

    public fun really_none<E: copy + drop + store>(): Self::T<E> {
    label b0:
        return Self::unwrap_or<Self::T<E>>(Self::none<Self::T<E>>(), Self::none<E>());
    }
}
