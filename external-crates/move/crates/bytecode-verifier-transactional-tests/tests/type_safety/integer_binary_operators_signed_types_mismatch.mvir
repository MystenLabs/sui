//# init --edition development

// Signed cross-type mismatches

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i8 + 0i64;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i16 * 0i128;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i32 - 0i256;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i64 / 0i8;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i128 % 0i16;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i256 & 0i32;
    return;
}
}

// Cross-signedness mismatches

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i8 + 0u8;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0u8 + 0i8;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0u64 - 0i64;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i64 - 0u64;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0u128 * 0i128;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i16 | 0u16;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0u32 ^ 0i32;
    return;
}
}

//# run
module 0x42.m {
entry foo() {
label b0:
    _ = 0i256 / 0u256;
    return;
}
}
