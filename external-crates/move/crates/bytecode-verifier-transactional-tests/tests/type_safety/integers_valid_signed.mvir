//# init --edition development

//# publish
module 0x42.ti8 {
test() {
let x: i8;
label l0:
    x = 0i8;
    x = 100i8;
    x = 1i8 + 1i8;
    x = 1i8 - 1i8;
    x = 1i8 * 1i8;
    x = 1i8 / 1i8;
    x = 1i8 % 1i8;
    x = 1i8 & 1i8;
    x = 1i8 | 1i8;
    x = 1i8 ^ 1i8;
    x = 1i8 << 1u8;
    x = 1i8 >> 1u8;
    return;
}
}

