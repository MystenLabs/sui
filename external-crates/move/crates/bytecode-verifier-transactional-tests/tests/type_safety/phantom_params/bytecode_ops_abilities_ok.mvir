//# publish

// Test checking that type arguments used in phantom position (phantom arguments)
// are not considered when deriving the abilities for a struct/enum by checking against
// abilities required for specific bytecode operatiosn.

mvir 0x1::M {
    public struct NoAbilities { a: bool }
    public struct HasDrop<phantom T1, T2> has drop { a: bool }
    public struct HasCopy<phantom T1, T2> has copy { a : bool }
    public struct HasStore<phantom T1, T2> has store { a: bool }
    public struct HasKey<phantom T1, T2> has key { a : bool }
    public struct RequireStore<T: store> { a: bool }

    // `WriteRef` requires drop
    fun f1(ref: &mut Self::HasDrop<Self::NoAbilities, u64>) {
    label b0:
        *move(ref) = HasDrop<Self::NoAbilities, u64> { a: true };
        return;
    }

    // `Pop` requires drop
    fun f2() {
    label b0:
        _ = HasDrop<Self::NoAbilities, u64> { a: true };
        return;
    }

    // Leaving value in local requires drop
    fun f3(x: Self::HasDrop<Self::NoAbilities, u64>) {
    label b0:
        return;
    }

    // `CopyLoc` requires copy
    fun f4(x: Self::HasCopy<Self::NoAbilities, u64>): Self::HasCopy<Self::NoAbilities, u64> * Self::HasCopy<Self::NoAbilities, u64> {
    label b0:
        return (copy(x), move(x));
    }

    fun f8(): Self::RequireStore<Self::HasStore<Self::NoAbilities, u64>> {
    label b0:
        return RequireStore<Self::HasStore<Self::NoAbilities, u64>> { a: true };
    }
}

//# publish
mvir 0x2::M {
    public enum NoAbilities { V{ a: bool } }
    public enum HasDrop<phantom T1, T2> has drop { V{ a: bool }}
    public enum HasCopy<phantom T1, T2> has copy { V{ a : bool }}
    public enum HasStore<phantom T1, T2> has store { V{ a: bool }}
    public enum HasKey<phantom T1, T2> has key { V{ a : bool } }
    public enum RequireStore<T: store> { V{ a: bool }}

    // `WriteRef` requires drop
    fun f1(ref: &mut Self::HasDrop<Self::NoAbilities, u64>) {
    label b0:
        *move(ref) = HasDrop::V<Self::NoAbilities, u64> { a: true };
        return;
    }

    // `Pop` requires drop
    fun f2() {
    label b0:
        _ = HasDrop::V<Self::NoAbilities, u64> { a: true };
        return;
    }

    // Leaving value in local requires drop
    fun f3(x: Self::HasDrop<Self::NoAbilities, u64>) {
    label b0:
        return;
    }

    // `CopyLoc` requires copy
    fun f4(x: Self::HasCopy<Self::NoAbilities, u64>): Self::HasCopy<Self::NoAbilities, u64> * Self::HasCopy<Self::NoAbilities, u64> {
    label b0:
        return (copy(x), move(x));
    }

    fun f8(): Self::RequireStore<Self::HasStore<Self::NoAbilities, u64>> {
    label b0:
        return RequireStore::V<Self::HasStore<Self::NoAbilities, u64>> { a: true };
    }
}
