//# run
mvir 0x42::m {

entry fun foo() {
    let v: vector<u8>;
    let v_mut: &mut vector<u8>;
    let e: u64;
label b0:
    v = vector<u8; 0>();
    v_mut = &mut v;
    vec_push_back<u8>(copy(v_mut), 0);

    e = vec_pop_back<u8>(move(v_mut));
    return;
}

}
//# run
mvir 0x42::m {

entry fun foo() {
    let v: vector<u8>;
    let v_mut: &mut vector<u8>;
    let i1: u8;
    let i2: u128;
label b0:
    i1 = 0;
    i2 = 1;
    v = vector<u8; 0>();
    v_mut = &mut v;
    vec_swap<u8>(move(v_mut), move(i1), move(i2));

    return;
}

}
// push int on the stack, then try to pack into vector of the wrong type
//# run
mvir 0x42::m {

entry fun foo() {
    let v: vector<bool>;
label b0:
    v = vector<bool; 1>(28u8);
    return;
}

}
// create vector<T>, try to unpack into different type
//# run
mvir 0x42::m {

entry fun foo() {
    let v: vector<u8>;
    let x: bool;
    let y: bool;
label b0:
    v = vector<u8; 2>(1u8, 0u8);
    vector<bool; 2>(x, y) = move(v);
    return;
}

}
