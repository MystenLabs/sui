    public fun bench_load_vec_256_accumulate() {
        let mut i: u64 = 0;
        let mut acc: u64 = 0;
        while (i < COUNT) {
            let v = VEC_256;
            acc = acc + (*v.borrow(0) as u64) + (*v.borrow(255) as u64);
            acc = acc % 1000000;
            i = i + 1;
        }
    }

    public fun bench_load_vec_1k_accumulate() {
