// Tests rename for basic Move constructs
{
  "Rename": {
    "project": "tests/rename",
    "file_tests": {
      "M1.move": [
        // Struct 'MyStruct' at definition
        {
          "use_line": 5,
          "use_ndx": 0,
          "new_name": "Data"
        },
        // Field 'value' at definition
        {
          "use_line": 6,
          "use_ndx": 0,
          "new_name": "amount"
        },
        // Function 'helper' at definition
        {
          "use_line": 18,
          "use_ndx": 0,
          "new_name": "compute"
        },
        // Constant 'MY_CONST' at definition
        {
          "use_line": 24,
          "use_ndx": 0,
          "new_name": "LIMIT"
        },
        // Function 'helper' from call site
        {
          "use_line": 21,
          "use_ndx": 0,
          "new_name": "compute"
        },
        // Local variable 'x'
        {
          "use_line": 31,
          "use_ndx": 0,
          "new_name": "val"
        }
      ],
      "M2.move": [
        // Function 'create' from partially qualified call site (M1::create)
        {
          "use_line": 9,
          "use_ndx": 1,
          "new_name": "make"
        }
      ],
      "M3.move": [
        // Type param 'T' on function
        {
          "use_line": 5,
          "use_ndx": 1,
          "new_name": "U"
        },
        // Type param 'T' on struct
        {
          "use_line": 9,
          "use_ndx": 1,
          "new_name": "U"
        },
        // Type param 'T' on enum
        {
          "use_line": 17,
          "use_ndx": 1,
          "new_name": "U"
        }
      ]
    }
  }
}
