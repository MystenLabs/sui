module 14::m {
fun main() {
    assert!(0i256 % 1i256 == 0i256, 5000);
    assert!(1i256 % 1i256 == 0i256, 5001);
    assert!(1i256 % 2i256 == 1i256, 5002);

    assert!(800i256 % 30i256 == 20i256, 5100);

