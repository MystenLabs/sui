// Multiplication: happy path
//# run
module 7::m {
fun main() {
    assert!(0i256 * 0i256 == 0i256, 3000);
    assert!(1i256 * 0i256 == 0i256, 3001);
    assert!(1i256 * 1i256 == 1i256, 3002);

    assert!(600i256 * 700i256 == 420000i256, 3100);

    // Negative operands
    assert!(-1i256 * 1i256 == -1i256, 3200);
    assert!(-1i256 * -1i256 == 1i256, 3201);
    assert!(-600i256 * 700i256 == -420000i256, 3202);

    // Boundary
    assert!(
        1i256 * 57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        == 57896044618658097711785492504343953926634992332820282019728792003956564819967i256,
        3300
    );
    assert!(
        -1i256 * 57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        == -57896044618658097711785492504343953926634992332820282019728792003956564819967i256,
        3301
    );
    assert!(
        1i256 * -57896044618658097711785492504343953926634992332820282019728792003956564819968i256
        == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256,
        3302
    );
}
}

