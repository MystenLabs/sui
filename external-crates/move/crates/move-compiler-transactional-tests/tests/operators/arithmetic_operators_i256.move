// Subtraction: happy path
//# run
module 4::m {
fun main() {
    assert!(0i256 - 0i256 == 0i256, 2000);
    assert!(1i256 - 0i256 == 1i256, 2001);
    assert!(1i256 - 1i256 == 0i256, 2002);

    // Negative operands
    assert!(-1i256 - -1i256 == 0i256, 2300);

    // Mixed signs
    assert!(0i256 - 1i256 == -1i256, 2400);

    // Boundary
    assert!(
        -57896044618658097711785492504343953926634992332820282019728792003956564819968i256 - 0i256
        == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256,
        2500
    );
    assert!(
        -1i256 - 57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256,
        2501
    );
}
}

