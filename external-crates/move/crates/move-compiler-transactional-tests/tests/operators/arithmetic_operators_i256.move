// Division: happy path
//# run
module 10::m {
fun main() {
    assert!(0i256 / 1i256 == 0i256, 4000);
    assert!(1i256 / 1i256 == 1i256, 4001);
    assert!(1i256 / 2i256 == 0i256, 4002);

    assert!(60000i256 / 300i256 == 200i256, 4100);

    // Negative operands
    assert!(-60000i256 / 300i256 == -200i256, 4200);
    assert!(60000i256 / -300i256 == -200i256, 4201);
    assert!(-60000i256 / -300i256 == 200i256, 4202);

    // Truncation toward zero
    assert!(7i256 / 2i256 == 3i256, 4300);
    assert!(-7i256 / 2i256 == -3i256, 4301);
    assert!(7i256 / -2i256 == -3i256, 4302);
    assert!(-7i256 / -2i256 == 3i256, 4303);

    // Boundary
    assert!(
        57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        / 57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        == 1i256,
        4400
    );
    assert!(
        -57896044618658097711785492504343953926634992332820282019728792003956564819968i256 / 1i256
        == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256,
        4401
    );
}
}

