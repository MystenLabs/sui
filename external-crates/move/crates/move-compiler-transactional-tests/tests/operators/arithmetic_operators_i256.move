//# init --edition development

// Addition: happy path
//# run
module 1::m {
fun main() {
    assert!(0i256 + 0i256 == 0i256, 1000);
    assert!(0i256 + 1i256 == 1i256, 1001);
    assert!(1i256 + 1i256 == 2i256, 1002);

    assert!(
        0i256 + 57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        == 57896044618658097711785492504343953926634992332820282019728792003956564819967i256,
        1200
    );

    // Negative operands
    assert!(-1i256 + -1i256 == -2i256, 1300);
    assert!(
        0i256 + -57896044618658097711785492504343953926634992332820282019728792003956564819968i256
        == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256,
        1302
    );

    // Mixed signs
    assert!(1i256 + -1i256 == 0i256, 1400);
    assert!(
        57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        + -57896044618658097711785492504343953926634992332820282019728792003956564819967i256
        == 0i256,
        1401
    );
}
}

// Addition: overflow (positive)
//# run
module 2::m {
fun main() {
    // should fail
    57896044618658097711785492504343953926634992332820282019728792003956564819967i256 + 1i256;
}
}

