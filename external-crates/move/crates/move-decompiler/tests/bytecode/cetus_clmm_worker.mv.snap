fun get_mkt_sell_amount(l0: u64, l1: u64, l2: u64): u64 {
    if (l0 == 0u64) {
        return 0u64
    } else {
        let l3 = if (l1 > 0u64) {
            l2 > 0u64
        } else {
            false
        };
        if (l3) {
            let l4 = l0 * 9980u64;
            let l6 = l4as u128 * l2as u128;
            let l5 = l1as u128 * 10000u128 + l4as u128;
            return l6 / l5as u64
        } else {
            abort C5
        }
    }
}

