public fun get_state_info(l0: &MMState): ( u64, u64, u64, bool) {
    return (mm_state::current_price(l0), mm_state::current_spread(l0), mm_state::execution_count(l0), mm_state::is_paused(l0))
}

public fun pause_trading<T0, T1>(l0: &mut MMState, l1: &mut BalanceManager, l2: &mut Pool<T0, T1>, l3: u64, l4: &Clock, l5: &TxContext) {
    assert!(mm_state::owner(freeze(l0)) == tx_context::sender(l5), C0);
    let l6 = clock::timestamp_ms(l4);
    let l7 = balance_manager::generate_proof_as_owner(l1, l5);
    pool::cancel_all_orders(l2, l1, &l7, l4, l5);
    events::emit_orders_cancelled(mm_state::state_id(freeze(l0)), object::id(freeze(l2)), l6);
    mm_state::pause(l0, l6 + l3, l6)
}

public fun resume_trading(l0: &mut MMState, l1: &TxContext) {
    assert!(mm_state::owner(freeze(l0)) == tx_context::sender(l1), C0);
    mm_state::unpause(l0)
}
