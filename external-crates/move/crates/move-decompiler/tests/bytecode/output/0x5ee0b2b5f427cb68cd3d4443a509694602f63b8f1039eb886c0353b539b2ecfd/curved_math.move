        } else {
            l31 = l31 - l14;
            let l18 = l31 / l27;
            let l28 = l23 / l18;
            let l29 = l31 + l3 * C0 / l18 + math::mul_div_u256(l28, C0, l10);
            l28 = l28 + math::mul_div_u256(l12, C0, l18);
            l27 = if (l29 < l28) {
