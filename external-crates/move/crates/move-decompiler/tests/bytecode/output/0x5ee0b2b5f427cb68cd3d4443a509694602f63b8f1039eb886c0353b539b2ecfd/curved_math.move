    loop {
        if (l22 <= l25 - 2u64) {
            let l16 = (&l26)[l22];
            l27 = math::mul_div_u256(l27, l3, l16 * l25as u256);
            l13 = l13 + l16;
            if (l22 != 0u64) {
                l22 = l22 - 1u64;
                continue
            }
        };
        l22 = 0u64;
        break
    };
    while (l22 < l25 - 1u64) {
        l11 = math::mul_div_u256(l11, (&l26)[l22] * l25as u256, l3);
        l22 = l22 + 1u64;
    };
    l22 = 0u64;
    let l9;
    loop {
