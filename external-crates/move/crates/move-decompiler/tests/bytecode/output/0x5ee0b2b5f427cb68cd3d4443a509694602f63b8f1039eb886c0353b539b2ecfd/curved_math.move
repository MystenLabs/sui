    };
    let l13 = C0;
    let l14 = 5u256 * math::pow_10_u256(17u8);
    let l12 = l13;
    let l9 = false;
    let l5 = 1u256;
    loop {
        assert!(l5 < 256u256, C14);
        let l7 = l5 * C0;
        let l3 = l7 - C0;
        if (l4 > l3) {
            l3 = l4 - l3;
            l9 = !(l9);
        } else {
            l3 = l3 - l4;
        };
        let l8 = math::mul_div_u256(l3, l14, C0);
        l13 = math::mul_div_u256(l13, l8, l7);
        l12 = if (l9) {
            l12 - l13
        } else {
            l12 + l13
        };
        if (l13 < l2) {
            return math::mul_div_u256(l12, l11, C0)
        };
        l5 = l5 + 1u256;
    }
}

