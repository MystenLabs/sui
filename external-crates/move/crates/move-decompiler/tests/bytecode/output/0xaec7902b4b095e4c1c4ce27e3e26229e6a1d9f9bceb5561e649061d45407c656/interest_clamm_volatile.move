public fun quote_swap<T0, T1, T2>(l0: &mut InterestPool<Volatile>, l1: &Clock, l2: u64): u64 {
    if (l2 == 0u64) {
        return 0u64
    };
    let (reg_7, reg_8) = interest_clamm_volatile::state_and_coin_states(l0);
    let l19 = reg_7;
    let l9 = interest_clamm_volatile::coin_state(l19);
    let l11 = interest_clamm_volatile::coin_state(l19);
    let (reg_15, reg_16) = interest_clamm_volatile::get_a_gamma(l19, l1);
    let l8 = C15;
    let l16 = 0u64;
    let l17 = utils::to_u64(*(&l19.n_coins));
    while (l17 > l16) {
        let l7 = *(&(&l19.balances)[l16]);
        let l12 = *(&(&reg_8)[l16]);
        l7 = if (l16 == *(&(&l9).index)) {
            l7 + fixed_point_wad::div_down(utils::to_u256(l2), *(&(&l9).decimals_scalar))
        } else {
            l7
        };
        let l5 = &mut l8;
        let l4 = if (l16 == 0u64) {
            l7
        } else {
            fixed_point_wad::mul_down(l7, *(&(&l12).price))
        };
        l5.push_back(l4);
        l16 = l16 + 1u64;
    };
    let l20 = volatile_math::y(reg_15, reg_16, &l8, *(&l19.d), *(&(&l11).index)) + 1u256;
    let l14 = *(&(&l8)[*(&(&l11).index)]);
    let l10 = l14 - math256::min(l14, l20);
    let l18 = &mut (&mut l8)[*(&(&l11).index)];
    *l18 = *l18 - l10;
    if (*(&(&l11).index) != 0u64) {
        l10 = fixed_point_wad::div_down(l10, *(&(&l11).price));
    };
    return utils::to_u64(fixed_point_wad::mul_down(l10 - interest_clamm_volatile::fee_impl(l19, l8) * l10 / 10000000000u256, *(&(&l11).decimals_scalar)))
}

public fun ramp<T0>(l0: &mut InterestPool<Volatile>, l1: &PoolAdmin, l2: &Clock, l3: u256, l4: u256, l5: u64) {
    interest_pool::assert_pool_admin(freeze(l0), l1);
    let l11 = clock::timestamp_ms(l2);
    let l8 = interest_pool::addy(freeze(l0));
    let l10 = interest_clamm_volatile::load_mut(interest_pool::state_mut(l0));
    assert!(l11 >= *(&(&l10.a_gamma).initial_time) + C11, errors::wait_one_day());
    assert!(l5 >= l11 + C11, errors::future_ramp_time_is_too_short());
    let (reg_33, reg_34) = interest_clamm_volatile::get_a_gamma(freeze(l10), l2);
    let l7 = reg_34;
    let l6 = reg_33;
    assert!(l3 >= *(&l10.min_a), errors::future_a_is_too_small());
    assert!(*(&l10.max_a) >= l3, errors::future_gamma_is_too_big());
    assert!(l4 >= C3, errors::future_gamma_is_too_small());
    assert!(l4 <= C9, errors::future_gamma_is_too_big());
    let l9 = fixed_point_wad::div_down(l3, l6);
    assert!(C10 * C6 >= l9, errors::future_a_change_is_too_big());
    assert!(l9 >= C6 / C10, errors::future_a_change_is_too_small());
    l9 = fixed_point_wad::div_down(l4, l7);
    assert!(C10 * C6 >= l9, errors::future_gamma_change_is_too_big());
    assert!(l9 >= C6 / C10, errors::future_gamma_change_is_too_small());
    *(&mut (&mut l10.a_gamma).a) = l6;
    *(&mut (&mut l10.a_gamma).gamma) = l7;
    *(&mut (&mut l10.a_gamma).initial_time) = l11;
    *(&mut (&mut l10.a_gamma).future_a) = l3;
    *(&mut (&mut l10.a_gamma).future_gamma) = l4;
    *(&mut (&mut l10.a_gamma).future_time) = l5;
    interest_clamm_volatile::increment_version(l10);
    pool_events::emit_ramp_a_gamma(l8, l6, l7, l11, l3, l4, l5)
}

