        let l5 = utils::to_u256(l1 - 1u64) * *(&(&l8.balances)[l6]) / l9;
        let l3 = *(&(&reg_2)[l6]);
        (&mut l2).push_back(utils::to_u64(fixed_point_wad::mul_down(l5, *(&(&l3).decimals_scalar))));
        l6 = l6 + 1u64;
    };
    return l2
}

