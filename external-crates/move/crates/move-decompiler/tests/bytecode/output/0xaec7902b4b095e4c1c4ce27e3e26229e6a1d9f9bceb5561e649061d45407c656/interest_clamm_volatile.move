public(friend) fun remove_liquidity_2_pool_impl<T0, T1, T2>(l0: &mut InterestPool<Volatile>, l1: Coin<T2>, l2: vector<u64>, l3: &mut TxContext): ( Coin<T0>, Coin<T1>) {
    assert!(coin::value(&l1) != 0u64, errors::no_zero_coin());
    let l7 = interest_pool::addy(freeze(l0));
    assert!(interest_pool::are_coins_ordered(freeze(l0), vector[x1_type_name::get(), x1_type_name::get()]), errors::coins_must_be_in_order());
    let l8 = interest_clamm_volatile::load_mut(interest_pool::state_mut(l0));
    let l9 = balance::supply_value(&l8.lp_coin_supply);
    let l6 = balance::decrease_supply(&mut l8.lp_coin_supply, coin::into_balance(l1));
    *(&mut l8.d) = *(&l8.d) - *(&l8.d) * utils::to_u256(l6) / utils::to_u256(l9);
