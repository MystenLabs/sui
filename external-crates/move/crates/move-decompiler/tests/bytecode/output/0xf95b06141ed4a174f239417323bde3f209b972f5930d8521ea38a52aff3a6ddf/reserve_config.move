fun validate_utils_and_aprs(l0: &vector<u8>, l1: &vector<u64>) {
    assert!(l0.len() >= 2u64, C0);
    assert!(l0.len() == l1.len(), C0);
    let l3 = l0.len();
    assert!(*(&l0[0u64]) == 0u8, C0);
    assert!(*(&l0[l3 - 1u64]) == 100u8, C0);
    let l2 = 1u64;
    loop {
        if (l2 < l3) {
            assert!(*(&l0[l2 - 1u64]) < *(&l0[l2]), C0);
            assert!(*(&l1[l2 - 1u64]) <= *(&l1[l2]), C0);
            l2 = l2 + 1u64;
            continue
        };
        return
    }
}

