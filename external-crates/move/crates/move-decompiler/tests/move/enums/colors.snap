module colors {
    public fun is_blue () {
        let l3 = l0;
        let l2 = &l3;
        let l1;
        l1 =         match(l2: colors::Color) {
            colors::Color::Red => {
false            },
            colors::Color::Green => {
false            },
            colors::Color::Blue => {
                let colors::Color::Blue {} = l3;
true            },
        }
;
        return l1
    }

