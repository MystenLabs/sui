module geometry {
    public fun get_area () {
        let l4 = l0;
        let l3 = &l4;
        let l1 = match(l3: Shape) {
            Shape::Square { side: reg_4 } => {
                let Shape::Square { side: reg_6 } = l4;
                let l7 = reg_6 : u64;
                l7 * l7
            },
            Shape::Triangle { base: reg_11, height: reg_12 } => {
                let Shape::Triangle { base: reg_14, height: reg_15 } = l4;
                let l2 = reg_15 : u64;
                let l5 = reg_14 : u64;
                let l6 = l2;
                l5 * l6 / 2u64
            },
        };
        return l1
    }

    public fun get_square_side () {
        let l2 = l0;
        let l1 = l2;
        match(l1: Shape) {
            Shape::Square { side: reg_7 } => {
                let Shape::Square { side: reg_9 } = &l2;
                return                 *reg_9 : &u64
            },
            Shape::Triangle => {
                abort Constant { type_: U64, data: [1, 0, 0, 0, 0, 0, 0, 0] };
            },
        }
    }

    public fun get_triangle_size () {
        let l3 = l0;
        let l2 = l3;
        match(l2: Shape) {
            Shape::Square => {
                abort Constant { type_: U64, data: [1, 0, 0, 0, 0, 0, 0, 0] };
            },
            Shape::Triangle { base: reg_7, height: reg_8 } => {
                let Shape::Triangle { base: reg_10, height: reg_11 } = &l3;
                let l1 = reg_11 : &u64;
                let l4 = reg_10 : &u64;
                let l5 = l1;
                return                 *l4                *l5
            },
        }
    }

    public fun set_square_side () {
        let l3 = l0;
        let l2 =         l3;
        match(l2: Shape) {
            Shape::Square { side: reg_8 } => {
                let Shape::Square { side: reg_10 } = &mut l3;
                let l4 = reg_10 : &mut u64;
                *l4 = l1
                return 
            },
            Shape::Triangle => {
                abort Constant { type_: U64, data: [1, 0, 0, 0, 0, 0, 0, 0] };
            },
        }
    }

    public fun set_triangle_dimensions () {
        let l5 = l0;
        let l4 =         l5;
        match(l4: Shape) {
            Shape::Square => {
                abort Constant { type_: U64, data: [1, 0, 0, 0, 0, 0, 0, 0] };
            },
            Shape::Triangle { base: reg_8, height: reg_9 } => {
                let Shape::Triangle { base: reg_11, height: reg_12 } = &mut l5;
                let l3 = reg_12 : &mut u64;
                let l6 = reg_11 : &mut u64;
                let l7 = l3;
                *l6 = l1
                *l7 = l2
                return 
            },
        }
    }

}
