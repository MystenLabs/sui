module inline_immutable_alias {
    public fun add_one () {
        *l0 =         *l0 + 1u64
    }

    public fun mut_borrow_blocks_inline () {
        let l0 = 0u64;
        let l1 = l0;
        inline_immutable_alias::add_one(&mut l0)
        return l1
    }

    public fun stage () {
        return l0 + l1 + l0 + l1
    }

}
