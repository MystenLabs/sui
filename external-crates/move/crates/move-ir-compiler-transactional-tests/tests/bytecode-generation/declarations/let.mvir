//# print-bytecode
mvir 0x6::m {
// `let` generates a local with the given type.
entry fun foo() {
    let x: u64;
label b0:
    return;
}
}

//# print-bytecode
mvir 0x6::m {
// Two `let` cannot use the same name for a local.
entry fun foo() {
    let x: u64;
    let x: u64;
label b0:
    return;
}
}
