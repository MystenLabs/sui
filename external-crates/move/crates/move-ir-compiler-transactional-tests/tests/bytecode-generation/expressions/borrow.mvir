//# print-bytecode
// Attempting an immutable borrow of the field of a struct type defined in a
// separate module is invalid.
mvir 0x3d4::N {
    import 0x1::signer;
    import 0x3d4::M;

    fun f(account: signer) {
        let t: M::T;
        let r: &bool;
    label b0:
        t = M::new();
        _ = &(&mut t).T::b;
        return;
    }
}

