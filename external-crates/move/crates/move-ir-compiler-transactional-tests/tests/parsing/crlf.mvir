//# print-bytecode
mvir 0x6::m {
entry fun foo() {
label b0:
    // return;
    return;
}
}

//# print-bytecode
mvir 0x7::m {
entry fun foo() {
label b0:
    // return;
    // return;
    return;
}
}

//# print-bytecode
mvir 0x8::m {
entry fun foo() {
label b0:
    return; // return;
}
}

//# print-bytecode
mvir 0x9::m {
entry fun foo() {
label b0:
    // return;
    return; // return;
}
}

//# print-bytecode
mvir 0xa::m {
// In Move, /* */ are block comment delimiters. Not so in Move IR, so the `/*` below
// cannot be parsed.
entry fun foo() {
label b0:
    return;
    /* return; */
}
}

//# print-bytecode
mvir 0xb::m {
// Since /* */ are not block comment delimiters, they do not behave in any unique way when
// they appear within comments.
entry fun foo() {
label b0:
    // /*
    return;
    // */
}
}
