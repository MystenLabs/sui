//# run
mvir 0x5::m {

entry fun foo() {
    let v1: vector<u64>;
    let v2: vector<u64>;
    let e: u64;
label b0:
    v1 = vector<u64; 1>(42);
    vector<u64; 1>(e) = move(v1);
    v2 = vector<u64; 1>(move(e));
    assert(*vec_imm_borrow<u64>(&v2, 0) == 42, 42);

    return;
}

}
//# run
mvir 0x6::m {

entry fun foo() {
    let v1: vector<u64>;
    let v2: vector<u64>;
    let e1: u64;
    let e2: u64;
label b0:
    v1 = vector<u64; 2>(42, 43);
    vector<u64; 2>(e1, e2) = move(v1);
    v2 = vector<u64; 2>(move(e1), move(e2));
    assert(*vec_imm_borrow<u64>(&v2, 0) == 42, 42);
    assert(*vec_imm_borrow<u64>(&v2, 1) == 43, 43);

    return;
}

}
