//# run
// Each constant, loaded via LdConst, must equal the same value built from a
// literal/expression at runtime. Cross-checks the constant parsing and serialization against the
// expressions.
mvir 0x42::m {
    const B: bool          = true;
    const N8: u8           = 7u8;
    const N16: u16         = 7u16;
    const N32: u32         = 7u32;
    const N64: u64         = 42u64;
    const N128: u128       = 42u128;
    const N256: u256       = 42u256;
    const ADDR: address    = 0x42;
    const BYTES: vector<u8> = h"deadbeef";
    const NUMS: vector<u64> = vector(1u64, 2u64, 3u64);
    const EMPTY: vector<u8> = vector();
    const NESTED: vector<vector<u8>> = vector(vector(1u8), vector(2u8));

    entry fun check() {
    label b0:
        assert(const::B == true, 0);
        assert(const::N8 == 7u8, 1);
        assert(const::N16 == 7u16, 2);
        assert(const::N32 == 7u32, 3);
        assert(const::N64 == 42u64, 4);
        assert(const::N128 == 42u128, 5);
        assert(const::N256 == 42u256, 6);
        assert(const::ADDR == @0x42, 7);
        assert(const::BYTES == vector<u8; 4>(222u8, 173u8, 190u8, 239u8), 8);
        assert(const::NUMS == vector<u64; 3>(1u64, 2u64, 3u64), 9);
        assert(const::EMPTY == vector<u8; 0>(), 10);
        assert(const::NESTED == vector<vector<u8>; 2>(vector<u8; 1>(1u8), vector<u8; 1>(2u8)), 11);
        return;
    }
}
