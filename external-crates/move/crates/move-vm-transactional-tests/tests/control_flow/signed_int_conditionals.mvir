//# init --edition development

// Branch on negative value
//# run
module 0x42.m {

entry foo() {
    let x: i32;
    let result: u64;
label b0:
    x = -5i32;
    jump_if_false (copy(x) < 0i32) else_branch;
label then_branch:
    result = 1;
    jump done;
label else_branch:
    result = 2;
label done:
    assert(move(result) == 1, 1000);
    return;
}

}

// Branch on positive value
//# run
module 0x43.m {

entry foo() {
    let x: i32;
    let result: u64;
label b0:
    x = 5i32;
    jump_if_false (copy(x) < 0i32) else_branch;
label then_branch:
    result = 1;
    jump done;
label else_branch:
    result = 2;
label done:
    assert(move(result) == 2, 2000);
    return;
}

}

// Branch on zero (not negative)
//# run
module 0x44.m {

entry foo() {
    let x: i32;
    let result: u64;
label b0:
    x = 0i32;
    jump_if_false (copy(x) < 0i32) check_zero;
label is_neg:
    result = 1;
    jump done;
label check_zero:
    jump_if_false (copy(x) == 0i32) is_pos;
label is_zero:
    result = 0;
    jump done;
label is_pos:
    result = 2;
label done:
    assert(move(result) == 0, 3000);
    return;
}

}

// Boundary test: i8 minimum
//# run
module 0x45.m {

entry foo() {
    let x: i8;
    let result: u64;
label b0:
    x = -128i8;
    jump_if_false (copy(x) == -128i8) else_branch;
label then_branch:
    result = 1;
    jump done;
label else_branch:
    result = 0;
label done:
    assert(move(result) == 1, 5000);
    return;
}

}

// Boundary test: i8 maximum
//# run
module 0x46.m {

entry foo() {
    let x: i8;
    let result: u64;
label b0:
    x = 127i8;
    jump_if_false (copy(x) == 127i8) else_branch;
label then_branch:
    result = 1;
    jump done;
label else_branch:
    result = 0;
label done:
    assert(move(result) == 1, 6000);
    return;
}

}

// Comparing negative to positive
//# run
module 0x47.m {

entry foo() {
    let neg: i32;
    let pos: i32;
label b0:
    neg = -10i32;
    pos = 10i32;
    assert(copy(neg) < copy(pos), 8000);
    assert(!(copy(neg) > copy(pos)), 8001);
    assert(!(copy(neg) == copy(pos)), 8002);
    assert(copy(neg) != copy(pos), 8003);
    assert(copy(neg) <= copy(pos), 8004);
    assert(!(copy(neg) >= copy(pos)), 8005);
    return;
}

}

// Boundary: i16 min/max in conditionals
//# run
module 0x48.m {

entry foo() {
    let min: i16;
    let max: i16;
label b0:
    min = -32768i16;
    max = 32767i16;
    assert(copy(min) < copy(max), 10000);
    assert(copy(min) < 0i16, 10001);
    assert(copy(max) > 0i16, 10002);
    assert(copy(min) != copy(max), 10003);
    return;
}

}

// Nested branch: classify value into range
//# run
module 0x49.m {

entry foo() {
    let x: i32;
    let result: u64;
label b0:
    x = -50i32;
    jump_if_false (copy(x) < -100i32) check_neg;
label very_neg:
    result = 1;
    jump done;
label check_neg:
    jump_if_false (copy(x) < 0i32) check_pos;
label is_neg:
    result = 2;
    jump done;
label check_pos:
    jump_if_false (copy(x) < 100i32) is_very_pos;
label is_pos:
    result = 3;
    jump done;
label is_very_pos:
    result = 4;
label done:
    assert(move(result) == 2, 11000);
    return;
}

}
