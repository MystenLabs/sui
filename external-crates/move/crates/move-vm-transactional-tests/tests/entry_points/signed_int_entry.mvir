//# init --edition development

// Entry function that internally uses i8
//# run
module 0x6.m {

entry foo() {
    let x: i8;
    let y: i8;
label b0:
    x = 100i8;
    y = -50i8;
    assert(move(x) + move(y) == 50i8, 1000);
    return;
}

}

// Entry function that internally uses i64
//# run
module 0x7.m {

entry foo() {
    let x: i64;
    let y: i64;
label b0:
    x = -1000i64;
    y = 1000i64;
    assert(move(x) + move(y) == 0i64, 1100);
    return;
}

}

// Entry function using multiple signed int widths
//# run
module 0x8.m {

entry foo() {
    let a: i8;
    let b: i16;
    let c: i32;
    let d: i64;
    let e: i128;
label b0:
    a = -1i8;
    b = -1i16;
    c = -1i32;
    d = -1i64;
    e = -1i128;
    assert(move(a) == -1i8, 1200);
    assert(move(b) == -1i16, 1201);
    assert(move(c) == -1i32, 1202);
    assert(move(d) == -1i64, 1203);
    assert(move(e) == -1i128, 1204);
    return;
}

}

// Entry function with signed int arithmetic and comparisons
//# run
module 0x9.m {

entry foo() {
    let x: i64;
    let y: i64;
label b0:
    x = 50i64;
    y = -50i64;
    assert(copy(x) > copy(y), 1300);
    assert(copy(y) < copy(x), 1301);
    assert(move(x) != move(y), 1302);
    return;
}

}

// Entry function with negation
//# run
module 0xa.m {

entry foo() {
    let x: i8;
    let y: i8;
label b0:
    x = 42i8;
    y = neg(copy(x));
    assert(move(y) == -42i8, 1400);
    assert(neg(move(x)) == -42i8, 1401);
    return;
}

}
