//# print-bytecode
mvir 0x6::Enums {
    public enum EnumWithThreeVariants<T> {
        One { },
        Two { x: T },
        Three { } 
    }

    public fun call_success<T>(t: T): T {
        let x: Self::EnumWithThreeVariants<T>;
        label b0:
            x = EnumWithThreeVariants::Two<T> { x: move(t) };
            return Self::f<T>(move(x));
    }

    public fun call_fail_1<T>(): T {
        let x: Self::EnumWithThreeVariants<T>;
        label b0:
            x = EnumWithThreeVariants::One<T> { };
            return Self::f<T>(move(x));
    }


    public fun call_fail_3<T>(): T {
        let x: Self::EnumWithThreeVariants<T>;
        label b0:
            x = EnumWithThreeVariants::Three<T> { };
            return Self::f<T>(move(x));
    }

    fun f<T>(x: Self::EnumWithThreeVariants<T>): T {
        let y: T;
        label b0:
            variant_switch EnumWithThreeVariants (&x) {
                One : b1,
                Two : b1,
                Three : b1,
            };
        label b1:
            EnumWithThreeVariants::Two<T> { x: y } = move(x);
            return move(y);
    }
}

//# publish
mvir 0x6::Enums {
    public enum EnumWithThreeVariants<T> {
        One { },
        Two { x: T },
        Three { } 
    }

    public fun call_success<T>(t: T): T {
        let x: Self::EnumWithThreeVariants<T>;
        label b0:
            x = EnumWithThreeVariants::Two<T> { x: move(t) };
            return Self::f<T>(move(x));
    }

    public fun call_fail_1<T>(): T {
        let x: Self::EnumWithThreeVariants<T>;
        label b0:
            x = EnumWithThreeVariants::One<T> { };
            return Self::f<T>(move(x));
    }


    public fun call_fail_3<T>(): T {
        let x: Self::EnumWithThreeVariants<T>;
        label b0:
            x = EnumWithThreeVariants::Three<T> { };
            return Self::f<T>(move(x));
    }

    fun f<T>(x: Self::EnumWithThreeVariants<T>): T {
        let y: T;
        label b0:
            variant_switch EnumWithThreeVariants (&x) {
                One : b1,
                Two : b1,
                Three : b1,
            };
        label b1:
            EnumWithThreeVariants::Two<T> { x: y } = move(x);
            return move(y);
    }
}

//# run
mvir 0x7::m {
import 0x6::Enums;
entry fun foo() {
    let x: u64;
    label b0:
        x = Enums::call_success<u64>(42);
        assert(move(x) == 42, 100);
        return;
}
}

