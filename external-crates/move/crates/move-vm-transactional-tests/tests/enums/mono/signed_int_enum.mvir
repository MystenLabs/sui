//# init --edition development

//# print-bytecode
module 0x6.SignedIntEnums {
    enum SignedVal {
        Small { x: i8 },
        Large { x: i64 }
    }

    public make_small(v: i8): Self.SignedVal {
        label b0:
            return SignedVal.Small { x: move(v) };
    }

    public make_large(v: i64): Self.SignedVal {
        label b0:
            return SignedVal.Large { x: move(v) };
    }

    public get_or_default(e: Self.SignedVal): i64 {
        let s: i8;
        let l: i64;
        label b0:
            variant_switch SignedVal (&e) {
                Small : b1,
                Large : b2,
            };
        label b1:
            SignedVal.Small { x: s } = move(e);
            return (move(s) as i64);
        label b2:
            SignedVal.Large { x: l } = move(e);
            return move(l);
    }
}

//# publish
module 0x6.SignedIntEnums {
    enum SignedVal {
        Small { x: i8 },
        Large { x: i64 }
    }

    public make_small(v: i8): Self.SignedVal {
        label b0:
            return SignedVal.Small { x: move(v) };
    }

    public make_large(v: i64): Self.SignedVal {
        label b0:
            return SignedVal.Large { x: move(v) };
    }

    public get_or_default(e: Self.SignedVal): i64 {
        let s: i8;
        let l: i64;
        label b0:
            variant_switch SignedVal (&e) {
                Small : b1,
                Large : b2,
            };
        label b1:
            SignedVal.Small { x: s } = move(e);
            return (move(s) as i64);
        label b2:
            SignedVal.Large { x: l } = move(e);
            return move(l);
    }
}

//# run
module 0x7.m {
import 0x6.SignedIntEnums;
entry foo() {
    let small: SignedIntEnums.SignedVal;
    let large: SignedIntEnums.SignedVal;
    let v1: i64;
    let v2: i64;
    label b0:
        small = SignedIntEnums.make_small(-42i8);
        v1 = SignedIntEnums.get_or_default(move(small));
        assert(move(v1) == -42i64, 100);

        large = SignedIntEnums.make_large(-1000i64);
        v2 = SignedIntEnums.get_or_default(move(large));
        assert(move(v2) == -1000i64, 101);
        return;
}
}
