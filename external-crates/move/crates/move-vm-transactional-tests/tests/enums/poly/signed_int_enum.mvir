//# init --edition development

//# print-bytecode
module 0x6.SignedOption {
    enum Option<T> {
        None { },
        Some { val: T }
    }

    public some<T>(v: T): Self.Option<T> {
        label b0:
            return Option.Some<T> { val: move(v) };
    }

    public none<T>(): Self.Option<T> {
        label b0:
            return Option.None<T> { };
    }

    public unwrap_or<T: copy + drop>(e: Self.Option<T>, default: T): T {
        let v: T;
        label b0:
            variant_switch Option (&e) {
                None : b1,
                Some : b2,
            };
        label b1:
            Option.None<T> { } = move(e);
            return move(default);
        label b2:
            Option.Some<T> { val: v } = move(e);
            return move(v);
    }
}

//# publish
module 0x6.SignedOption {
    enum Option<T> {
        None { },
        Some { val: T }
    }

    public some<T>(v: T): Self.Option<T> {
        label b0:
            return Option.Some<T> { val: move(v) };
    }

    public none<T>(): Self.Option<T> {
        label b0:
            return Option.None<T> { };
    }

    public unwrap_or<T: copy + drop>(e: Self.Option<T>, default: T): T {
        let v: T;
        label b0:
            variant_switch Option (&e) {
                None : b1,
                Some : b2,
            };
        label b1:
            Option.None<T> { } = move(e);
            return move(default);
        label b2:
            Option.Some<T> { val: v } = move(e);
            return move(v);
    }
}

//# run
module 0x7.m {
import 0x6.SignedOption;
entry foo() {
    let some_i8: SignedOption.Option<i8>;
    let none_i64: SignedOption.Option<i64>;
    let v1: i8;
    let v2: i64;
    label b0:
        some_i8 = SignedOption.some<i8>(-127i8);
        v1 = SignedOption.unwrap_or<i8>(move(some_i8), 0i8);
        assert(move(v1) == -127i8, 100);

        none_i64 = SignedOption.none<i64>();
        v2 = SignedOption.unwrap_or<i64>(move(none_i64), -999i64);
        assert(move(v2) == -999i64, 101);
        return;
}
}
