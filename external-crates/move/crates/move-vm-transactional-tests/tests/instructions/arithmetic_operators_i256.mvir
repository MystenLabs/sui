//# init --edition development

// Addition: happy path
//# run
module 0x6.m {

entry foo() {
label b0:
    assert(0i256 + 0i256 == 0i256, 1000);
    assert(0i256 + 1i256 == 1i256, 1001);
    assert(1i256 + 1i256 == 2i256, 1002);

    assert(1000000i256 + 2000000i256 == 3000000i256, 1100);
    assert(0i256 + 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 == 57896044618658097711785492504343953926634992332820282019728792003956564819967i256, 1200);

    // Negative operands
    assert(-1i256 + -1i256 == -2i256, 1300);
    assert(0i256 + -57896044618658097711785492504343953926634992332820282019728792003956564819968i256 == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256, 1302);

    // Mixed signs
    assert(1i256 + -1i256 == 0i256, 1400);
    assert(57896044618658097711785492504343953926634992332820282019728792003956564819967i256 + -57896044618658097711785492504343953926634992332820282019728792003956564819967i256 == 0i256, 1403);
    return;
}

}
// Addition: overflow (positive)
//# run
module 0x7.m {

entry foo() {
label b0:
    _ = 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 + 1i256;
    return;
}

}
// Addition: overflow (negative)
//# run
module 0x8.m {

entry foo() {
label b0:
    _ = -57896044618658097711785492504343953926634992332820282019728792003956564819968i256 + -1i256;
    return;
}

}

// Subtraction: happy path
//# run
module 0x9.m {

entry foo() {
label b0:
    assert(0i256 - 0i256 == 0i256, 2000);
    assert(1i256 - 0i256 == 1i256, 2001);
    assert(1i256 - 1i256 == 0i256, 2002);

    assert(5000000i256 - 1300000i256 == 3700000i256, 2100);
    assert(57896044618658097711785492504343953926634992332820282019728792003956564819967i256 - 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 == 0i256, 2200);

    // Negative operands
    assert(-1i256 - -1i256 == 0i256, 2300);

    // Mixed signs
    assert(0i256 - 1i256 == -1i256, 2400);
    assert(-1i256 - 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256, 2501);
    return;
}

}
// Subtraction: overflow (positive)
//# run
module 0xa.m {

entry foo() {
label b0:
    _ = 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 - -1i256;
    return;
}

}
// Subtraction: overflow (negative)
//# run
module 0x42.m {

entry foo() {
label b0:
    _ = -57896044618658097711785492504343953926634992332820282019728792003956564819968i256 - 1i256;
    return;
}

}

// Multiplication: happy path
//# run
module 0xb.m {

entry foo() {
label b0:
    assert(0i256 * 0i256 == 0i256, 3000);
    assert(1i256 * 0i256 == 0i256, 3001);
    assert(1i256 * 1i256 == 1i256, 3002);

    assert(60000i256 * 70000i256 == 4200000000i256, 3100);

    // Negative operands
    assert(-1i256 * 1i256 == -1i256, 3200);
    assert(-1i256 * -1i256 == 1i256, 3201);
    assert(-60000i256 * 70000i256 == -4200000000i256, 3202);

    // Boundary
    assert(1i256 * 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 == 57896044618658097711785492504343953926634992332820282019728792003956564819967i256, 3300);
    assert(1i256 * -57896044618658097711785492504343953926634992332820282019728792003956564819968i256 == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256, 3302);
    return;
}

}
// Multiplication: overflow
//# run
module 0xc.m {

entry foo() {
label b0:
    _ = 28948022309329048855892746252171976963317496166410141009864396001978282409984i256 * 2i256;
    return;
}

}

// Division: happy path
//# run
module 0xe.m {

entry foo() {
label b0:
    assert(0i256 / 1i256 == 0i256, 4000);
    assert(1i256 / 1i256 == 1i256, 4001);
    assert(6i256 / 3i256 == 2i256, 4100);

    // Negative operands
    assert(-6i256 / 3i256 == -2i256, 4200);
    assert(6i256 / -3i256 == -2i256, 4201);
    assert(-6i256 / -3i256 == 2i256, 4202);

    // Truncation toward zero
    assert(7i256 / 2i256 == 3i256, 4300);
    assert(-7i256 / 2i256 == -3i256, 4301);

    assert(57896044618658097711785492504343953926634992332820282019728792003956564819967i256 / 57896044618658097711785492504343953926634992332820282019728792003956564819967i256 == 1i256, 4400);
    assert(-57896044618658097711785492504343953926634992332820282019728792003956564819968i256 / 1i256 == -57896044618658097711785492504343953926634992332820282019728792003956564819968i256, 4401);
    return;
}

}
// Division by zero
//# run
module 0x15.m {

entry foo() {
label b0:
    _ = 0i256 / 0i256;
    return;
}

}
//# run
module 0x16.m {

entry foo() {
label b0:
    _ = 1i256 / 0i256;
    return;
}

}

// Modulo: happy path
//# run
module 0x18.m {

entry foo() {
label b0:
    assert(0i256 % 1i256 == 0i256, 5000);
    assert(1i256 % 1i256 == 0i256, 5001);
    assert(8i256 % 3i256 == 2i256, 5100);

    // Negative operands
    assert(-8i256 % 3i256 == -2i256, 5200);
    assert(8i256 % -3i256 == 2i256, 5201);
    assert(-8i256 % -3i256 == -2i256, 5202);
    return;
}

}
// Modulo by zero
//# run
module 0x19.m {

entry foo() {
label b0:
    _ = 0i256 % 0i256;
    return;
}

}
