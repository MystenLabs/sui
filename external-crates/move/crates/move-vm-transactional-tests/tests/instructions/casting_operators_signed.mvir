//# init --edition development

// Signed-to-signed widening casts: i8 -> i64 preserves value including negatives.
//# run
module 0x6.m {

entry foo() {
label b0:
    assert(to_i64(0i8) == 0i64, 1000);
    assert(to_i64(1i8) == 1i64, 1001);
    assert(to_i64(127i8) == 127i64, 1002);
    assert(to_i64(-1i8) == -1i64, 1003);
    assert(to_i64(-128i8) == -128i64, 1004);

    // i8 -> i16
    assert(to_i16(0i8) == 0i16, 1100);
    assert(to_i16(127i8) == 127i16, 1101);
    assert(to_i16(-1i8) == -1i16, 1102);
    assert(to_i16(-128i8) == -128i16, 1103);

    // i8 -> i128
    assert(to_i128(0i8) == 0i128, 1200);
    assert(to_i128(-1i8) == -1i128, 1201);
    assert(to_i128(-128i8) == -128i128, 1202);

    // i16 -> i64
    assert(to_i64(0i16) == 0i64, 1300);
    assert(to_i64(-1i16) == -1i64, 1301);
    assert(to_i64(-32768i16) == -32768i64, 1302);

    // i32 -> i64
    assert(to_i64(0i32) == 0i64, 1400);
    assert(to_i64(-1i32) == -1i64, 1401);
    assert(to_i64(-2147483648i32) == -2147483648i64, 1402);
    return;
}

}

// Signed-to-signed narrowing: i64 -> i8 overflow aborts.
//# run
module 0x7.m {

entry foo() {
label b0:
    _ = to_i8(128i64);
    return;
}

}
//# run
module 0x8.m {

entry foo() {
label b0:
    _ = to_i8(-129i64);
    return;
}

}

// Signed-to-signed narrowing: i64 -> i8 in-range succeeds.
//# run
module 0x9.m {

entry foo() {
label b0:
    assert(to_i8(0i64) == 0i8, 2000);
    assert(to_i8(127i64) == 127i8, 2001);
    assert(to_i8(-128i64) == -128i8, 2002);
    assert(to_i8(-1i64) == -1i8, 2003);
    assert(to_i8(42i64) == 42i8, 2004);
    return;
}

}

// Cross-signedness: i8 -> u8 for non-negative values.
//# run
module 0xa.m {

entry foo() {
label b0:
    assert(to_u8(0i8) == 0u8, 3000);
    assert(to_u8(1i8) == 1u8, 3001);
    assert(to_u8(127i8) == 127u8, 3002);
    return;
}

}

// Cross-signedness: i8 -> u8 aborts for negative.
//# run
module 0xb.m {

entry foo() {
label b0:
    _ = to_u8(-1i8);
    return;
}

}
//# run
module 0xc.m {

entry foo() {
label b0:
    _ = to_u8(-128i8);
    return;
}

}

// Cross-signedness: u8 -> i8 for in-range values.
//# run
module 0xd.m {

entry foo() {
label b0:
    assert(to_i8(0u8) == 0i8, 4000);
    assert(to_i8(1u8) == 1i8, 4001);
    assert(to_i8(127u8) == 127i8, 4002);
    return;
}

}

// Cross-signedness: u8 -> i8 aborts for > 127.
//# run
module 0xe.m {

entry foo() {
label b0:
    _ = to_i8(128u8);
    return;
}

}
//# run
module 0x15.m {

entry foo() {
label b0:
    _ = to_i8(255u8);
    return;
}

}

// Cross-signedness: i64 -> u64 for non-negative values.
//# run
module 0x16.m {

entry foo() {
label b0:
    assert(to_u64(0i64) == 0u64, 5000);
    assert(to_u64(1i64) == 1u64, 5001);
    assert(to_u64(9223372036854775807i64) == 9223372036854775807u64, 5002);
    return;
}

}

// Cross-signedness: i64 -> u64 aborts for negative.
//# run
module 0x17.m {

entry foo() {
label b0:
    _ = to_u64(-1i64);
    return;
}

}

// Cross-signedness: u64 -> i64 aborts for > MAX_I64.
//# run
module 0x18.m {

entry foo() {
label b0:
    _ = to_i64(9223372036854775808u64);
    return;
}

}
