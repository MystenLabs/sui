//# run
mvir 0x6::m {

entry fun foo() {
    let x: vector<u64>;
    let r: &vector<u64>;
    label start:
        jump_if_false (true) end;
    label if_true:
        x = vec_pack_0<u64>();
        r = &x;
    label end:
        x = vec_pack_0<u64>();
        return;
}

}
//# run
mvir 0x7::m {

entry fun foo() {
    let x: vector<u64>;
    let r: &vector<u64>;
    label start:
        x = vec_pack_0<u64>();
        jump_if_false (true) end;
    label if_true:
        r = &x;
    label end:
        _ = move(x);
        return;
}

