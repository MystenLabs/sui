//# init --edition development

// Negate zero: -0 == 0.
//# run
module 0x6.m {

entry foo() {
label b0:
    assert(neg(0i8) == 0i8, 1000);
    assert(neg(0i16) == 0i16, 1001);
    assert(neg(0i32) == 0i32, 1002);
    assert(neg(0i64) == 0i64, 1003);
    assert(neg(0i128) == 0i128, 1004);
    assert(neg(0i256) == 0i256, 1005);
    return;
}

}

// Negate positive values.
//# run
module 0x7.m {

entry foo() {
label b0:
    assert(neg(1i8) == -1i8, 2000);
    assert(neg(1i16) == -1i16, 2001);
    assert(neg(1i32) == -1i32, 2002);
    assert(neg(1i64) == -1i64, 2003);
    assert(neg(1i128) == -1i128, 2004);
    assert(neg(1i256) == -1i256, 2005);

    assert(neg(127i8) == -127i8, 2100);
    assert(neg(42i64) == -42i64, 2101);
    return;
}

}

// Negate negative values (double negation).
//# run
module 0x8.m {

entry foo() {
label b0:
    assert(neg(-1i8) == 1i8, 3000);
    assert(neg(-1i16) == 1i16, 3001);
    assert(neg(-1i32) == 1i32, 3002);
    assert(neg(-1i64) == 1i64, 3003);
    assert(neg(-1i128) == 1i128, 3004);
    assert(neg(-1i256) == 1i256, 3005);

    assert(neg(-127i8) == 127i8, 3100);
    assert(neg(-42i64) == 42i64, 3101);
    return;
}

}

// Double negation: neg(neg(x)) == x.
//# run
module 0x9.m {

entry foo() {
label b0:
    assert(neg(neg(42i8)) == 42i8, 4000);
    assert(neg(neg(-42i8)) == -42i8, 4001);
    assert(neg(neg(42i64)) == 42i64, 4002);
    assert(neg(neg(-42i64)) == -42i64, 4003);
    assert(neg(neg(0i128)) == 0i128, 4004);
    return;
}

}

// Negate MIN aborts: -(-128) overflows i8.
//# run
module 0xa.m {

entry foo() {
label b0:
    _ = neg(-128i8);
    return;
}

}
// Negate MIN aborts: i16.
//# run
module 0xb.m {

entry foo() {
label b0:
    _ = neg(-32768i16);
    return;
}

}
// Negate MIN aborts: i32.
//# run
module 0xc.m {

entry foo() {
label b0:
    _ = neg(-2147483648i32);
    return;
}

}
// Negate MIN aborts: i64.
//# run
module 0xd.m {

entry foo() {
label b0:
    _ = neg(-9223372036854775808i64);
    return;
}

}
// Negate MIN aborts: i128.
//# run
module 0xe.m {

entry foo() {
label b0:
    _ = neg(-170141183460469231731687303715884105728i128);
    return;
}

}
