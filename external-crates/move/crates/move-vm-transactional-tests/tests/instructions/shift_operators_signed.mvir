//# init --edition development

// Shift >= bit_width aborts (i8, 8 bits)
//# run
module 0x6.m {

entry foo() {
label b0:
    _ = 0i8 << 8u8;
    return;
}

}
//# run
module 0x7.m {

entry foo() {
label b0:
    _ = 0i8 >> 8u8;
    return;
}

}

// Shift >= bit_width aborts (i64, 64 bits)
//# run
module 0x8.m {

entry foo() {
label b0:
    _ = 0i64 << 64u8;
    return;
}

}
//# run
module 0x9.m {

entry foo() {
label b0:
    _ = 0i64 >> 64u8;
    return;
}

}

// Shift >= bit_width aborts (i128, 128 bits)
//# run
module 0xa.m {

entry foo() {
label b0:
    _ = 0i128 << 128u8;
    return;
}

}
//# run
module 0xb.m {

entry foo() {
label b0:
    _ = 0i128 >> 128u8;
    return;
}

}

// Shifting 0 results in 0.
//# run
module 0xc.m {

entry foo() {
label b0:
    assert(0i8 << 4u8 == 0i8, 1000);
    assert(0i64 << 1u8 == 0i64, 1001);
    assert(0i128 << 127u8 == 0i128, 1002);

    assert(0i8 >> 4u8 == 0i8, 1100);
    assert(0i64 >> 1u8 == 0i64, 1101);
    assert(0i128 >> 127u8 == 0i128, 1102);
    return;
}

}

// Shifting by 0 bits results in the same number.
//# run
module 0xd.m {

entry foo() {
label b0:
    assert(100i8 << 0u8 == 100i8, 2000);
    assert(43i64 << 0u8 == 43i64, 2001);
    assert(-1i8 << 0u8 == -1i8, 2002);
    assert(-1i64 << 0u8 == -1i64, 2003);

    assert(100i8 >> 0u8 == 100i8, 2100);
    assert(43i64 >> 0u8 == 43i64, 2101);
    assert(-1i8 >> 0u8 == -1i8, 2102);
    assert(-1i64 >> 0u8 == -1i64, 2103);
    return;
}

}

// Left shift by 1 is multiply by 2.
//# run
module 0xe.m {

entry foo() {
label b0:
    assert(1i8 << 1u8 == 2i8, 3000);
    assert(7i64 << 1u8 == 14i64, 3001);
    assert(1i128 << 1u8 == 2i128, 3002);
    return;
}

}

// Arithmetic right shift: -1 >> n == -1 for any valid n.
//# run
module 0x15.m {

entry foo() {
label b0:
    assert(-1i8 >> 1u8 == -1i8, 4000);
    assert(-1i8 >> 7u8 == -1i8, 4001);
    assert(-1i64 >> 1u8 == -1i64, 4002);
    assert(-1i64 >> 63u8 == -1i64, 4003);
    assert(-1i128 >> 1u8 == -1i128, 4004);
    assert(-1i128 >> 127u8 == -1i128, 4005);
    return;
}

}

// Arithmetic right shift: -2 >> 1 == -1.
//# run
module 0x16.m {

entry foo() {
label b0:
    assert(-2i8 >> 1u8 == -1i8, 5000);
    assert(-2i64 >> 1u8 == -1i64, 5001);
    assert(-2i128 >> 1u8 == -1i128, 5002);

    // -128 >> 7 == -1 (all sign-extended)
    assert(-128i8 >> 7u8 == -1i8, 5100);

    // -4 >> 1 == -2
    assert(-4i8 >> 1u8 == -2i8, 5200);
    assert(-4i64 >> 1u8 == -2i64, 5201);
    return;
}

}

// Left shift of negative values.
//# run
module 0x17.m {

entry foo() {
label b0:
    // -1i8 << 1 == -2i8 (0xFF << 1 = 0xFE = -2)
    assert(-1i8 << 1u8 == -2i8, 6000);
    assert(-1i64 << 1u8 == -2i64, 6001);

    // -64i8 << 1 == -128i8
    assert(-64i8 << 1u8 == -128i8, 6100);
    return;
}

}
