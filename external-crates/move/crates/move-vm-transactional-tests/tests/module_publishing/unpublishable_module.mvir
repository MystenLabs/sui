//# publish
mvir 0x42::M {
    public fun num(): u64 {
        label b0:
            return 42;
    }
}

//# publish
unpublishable mvir 0x42::N {
    public fun num(): u64 {
        label b0:
            return 42;
    }
}

//# run
mvir 0x43::m {
import 0x42::M;
    entry fun foo() {
        let a: u64;
    label b0:
        a = M::num();
        assert(copy(a) == 42, 41);
        return;
    }
}
